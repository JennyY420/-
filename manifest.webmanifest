<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="theme-color" content="#3E6D9C">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="记账本">
<link rel="manifest" href="manifest.webmanifest">
<link rel="icon" type="image/png" sizes="192x192" href="icons/icon-192.png">
<link rel="apple-touch-icon" href="icons/apple-touch-icon.png">
<title>记账本 Ledger</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.4/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/tesseract.js/5.0.4/tesseract.min.js"></script>
<style>
  :root{
    --font-ui:'Manrope',system-ui,sans-serif;
    --font-num:'JetBrains Mono',monospace;
  }
  *{box-sizing:border-box;}
  html,body{ margin:0; min-height:100vh; }
  body{
    background:linear-gradient(160deg,#E9EEF4,#DAE2ED); font-family:var(--font-ui);
    display:flex; justify-content:center; transition:background .4s;
  }
  body.dark-bg{ background:linear-gradient(160deg,#0A0D18,#000000); }
  #shell{
    --accent:#3E6D9C; --bg1:#E9EEF4; --bg2:#DAE2ED;
    --glass:rgba(255,255,255,0.55); --glass-strong:rgba(255,255,255,0.72); --glass-border:rgba(255,255,255,0.65);
    --text:#1C2733; --text-soft:#647486; --text-faint:#93A1B0; --accent-soft:rgba(62,109,156,0.14);
    --expense:#B85C40; --expense-soft:rgba(184,92,64,0.14);
    --income:#238F6C; --income-soft:rgba(35,143,108,0.14);
    --warn:#C6432E;
    width:100%; max-width:460px; min-height:100vh; position:relative;
    background:var(--glass); backdrop-filter:blur(22px) saturate(180%); border-left:1px solid var(--glass-border); border-right:1px solid var(--glass-border);
    display:flex; flex-direction:column; transition:background .4s, color .4s;
    color:var(--text);
  }
  #shell.dark{
    --accent:#D4AF5A; --bg1:#0A0D18; --bg2:#000000;
    --glass:rgba(24,32,56,0.5); --glass-strong:rgba(30,40,68,0.68); --glass-border:rgba(212,175,90,0.28);
    --text:#F2EEE0; --text-soft:#9EA3BC; --text-faint:#6E7590; --accent-soft:rgba(212,175,90,0.16);
    --expense:#E0836A; --expense-soft:rgba(224,131,106,0.16);
    --income:#4FBF97; --income-soft:rgba(79,191,151,0.16);
    --warn:#E8604A;
  }

  header.top{
    padding:22px 20px 16px; border-bottom:1px solid var(--glass-border);
    display:flex; align-items:center; justify-content:space-between; position:relative; z-index:3;
  }
  header.top .brand{ display:flex; align-items:center; gap:10px; }
  header.top .mark{
    width:36px; height:36px; border-radius:11px; background:var(--glass-strong); backdrop-filter:blur(14px);
    border:1px solid var(--glass-border); display:flex; align-items:center; justify-content:center;
  }
  header.top .mark svg{ width:18px; height:18px; stroke:var(--accent); }
  header.top h1{ font-size:16.5px; margin:0; letter-spacing:0.2px; font-weight:800; }
  header.top .sub{ font-size:10.5px; color:var(--text-soft); margin-top:1px; font-family:var(--font-num); }
  .head-actions{ display:flex; align-items:center; gap:8px; }
  select#countrySelect{
    font-family:var(--font-ui); font-weight:700; font-size:12px; color:var(--text);
    background:var(--glass-strong); backdrop-filter:blur(14px); border:1px solid var(--glass-border);
    padding:7px 9px; border-radius:999px; cursor:pointer;
  }
  .icon-btn{
    width:34px; height:34px; border-radius:50%; background:var(--glass-strong); backdrop-filter:blur(14px);
    border:1px solid var(--glass-border); display:flex; align-items:center; justify-content:center; cursor:pointer;
  }
  .icon-btn svg{ width:16px; height:16px; stroke:var(--accent); }

  main{ flex:1; padding:16px 20px 96px; overflow-y:auto; position:relative; z-index:2; }
  svg.ic{ fill:none; stroke-width:1.6; stroke-linecap:round; stroke-linejoin:round; }

  .segmented{ display:flex; background:var(--glass); backdrop-filter:blur(14px); border:1px solid var(--glass-border); border-radius:999px; padding:4px; gap:4px; margin-bottom:18px; }
  .segmented button{
    flex:1; border:none; background:transparent; padding:9px 0; border-radius:999px;
    font-family:var(--font-ui); font-weight:700; font-size:13px; color:var(--text-soft); cursor:pointer;
  }
  .segmented button.active{ background:var(--glass-strong); color:var(--text); }
  .segmented button.active.income-active{ color:var(--income); }
  .segmented button.active.expense-active{ color:var(--expense); }

  h2.section-title{ font-size:11.5px; text-transform:uppercase; letter-spacing:0.09em; color:var(--text-faint); margin:20px 0 10px; font-weight:700;}
  h2.section-title:first-child{ margin-top:0; }

  .glass{ background:var(--glass); backdrop-filter:blur(16px) saturate(180%); border:1px solid var(--glass-border); border-radius:16px; }

  .datetime-row{ display:flex; align-items:center; justify-content:space-between; padding:13px 14px; margin-bottom:4px; }
  .datetime-row .tz-note{ font-size:10.5px; color:var(--text-soft); display:flex; align-items:center; gap:4px; }
  .datetime-row .tz-note svg{ width:12px; height:12px; stroke:var(--text-soft); }
  .datetime-row input[type=datetime-local]{
    border:none; background:transparent; font-family:var(--font-num); font-size:12.5px; color:var(--text); font-weight:600;
  }

  .cat-grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:9px; }
  .cat-item{ display:flex; flex-direction:column; align-items:center; gap:6px; cursor:pointer; }
  .cat-item .stamp{
    width:48px; height:48px; border-radius:15px; display:flex; align-items:center; justify-content:center;
    background:var(--glass); backdrop-filter:blur(14px); border:1px solid var(--glass-border); transition:all .15s;
  }
  .cat-item .stamp svg{ width:19px; height:19px; stroke:var(--text-soft); }
  .cat-item.selected .stamp{ border-color:var(--accent); box-shadow:0 0 0 1px var(--accent) inset; }
  .cat-item.selected .stamp svg{ stroke:var(--accent); }
  .cat-item span.lbl{ font-size:10.5px; color:var(--text-soft); text-align:center; }
  .cat-item.selected span.lbl{ color:var(--text); font-weight:700; }
  .cat-item.add-new .stamp svg{ stroke:var(--text-faint); }

  .receipt-drop{
    padding:20px; text-align:center; cursor:pointer; position:relative; margin-top:4px;
  }
  .receipt-drop.has-image{ padding:0; overflow:hidden; }
  .receipt-drop img{ width:100%; max-height:170px; object-fit:cover; display:block; border-radius:15px; }
  .receipt-drop svg{ width:22px; height:22px; stroke:var(--text-soft); margin-bottom:8px; }
  .receipt-drop .hint{ font-size:11.5px; color:var(--text-soft); }
  .receipt-drop .hint b{ color:var(--text); }
  .ocr-bar{ display:flex; align-items:center; gap:8px; margin-top:8px; font-size:11.5px; color:var(--accent); font-weight:600; }
  .spinner{ width:13px; height:13px; border-radius:50%; border:2px solid var(--accent-soft); border-top-color:var(--accent); animation:spin .7s linear infinite; }
  @keyframes spin{ to{ transform:rotate(360deg);} }

  .field{ margin-top:14px; }
  .field label{ font-size:10.5px; color:var(--text-soft); font-weight:700; text-transform:uppercase; letter-spacing:.05em; }
  .field input[type=text]{
    width:100%; margin-top:6px; padding:12px 14px; border-radius:14px; font-family:var(--font-ui); font-size:13.5px; color:var(--text);
  }
  .amount-row{ display:flex; gap:8px; margin-top:6px; align-items:center; }
  .amount-row input[type=number]{
    flex:1; padding:12px 14px; border-radius:14px; font-family:var(--font-num); font-size:18px; font-weight:700; color:var(--text);
  }
  input[type=text], input[type=number], input[type=datetime-local]{ background:var(--glass); backdrop-filter:blur(14px); border:1px solid var(--glass-border); }
  input::placeholder{ color:var(--text-faint); }
  .cur-toggle{ display:flex; border-radius:12px; overflow:hidden; border:1px solid var(--glass-border); }
  .cur-toggle button{ border:none; background:var(--glass); padding:10px 12px; font-family:var(--font-num); font-weight:700; font-size:12.5px; color:var(--text-soft); cursor:pointer; }
  .cur-toggle button.active{ background:var(--accent); color:var(--bg2); }
  .convert-note{ font-size:11px; color:var(--text-faint); margin-top:6px; font-family:var(--font-num); }

  .submit-btn{
    width:100%; margin-top:22px; padding:14px; border:none; border-radius:14px; font-family:var(--font-ui);
    font-weight:800; font-size:13.5px; cursor:pointer; color:#fff; letter-spacing:.02em;
  }
  .submit-btn.expense-btn{ background:var(--expense); box-shadow:0 8px 20px var(--expense-soft); }
  .submit-btn.income-btn{ background:var(--income); box-shadow:0 8px 20px var(--income-soft); }

  .period-bar{ display:flex; background:var(--glass); backdrop-filter:blur(14px); border:1px solid var(--glass-border); border-radius:999px; padding:3px; margin-bottom:14px; }
  .period-bar button{ flex:1; border:none; background:transparent; padding:7px 0; border-radius:999px; font-size:11.5px; font-weight:700; color:var(--text-soft); cursor:pointer; font-family:var(--font-ui); }
  .period-bar button.active{ background:var(--glass-strong); color:var(--text); }
  .period-nav{ display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; }
  .period-nav button{ border:1px solid var(--glass-border); background:var(--glass); width:30px; height:30px; border-radius:50%; cursor:pointer; display:flex; align-items:center; justify-content:center; }
  .period-nav button svg{ width:14px; height:14px; stroke:var(--text); }
  .period-nav .label{ font-size:12.5px; font-weight:700; color:var(--text-soft); font-family:var(--font-num);}

  .summary-cards{ display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:18px; }
  .summary-cards .card{ padding:14px; }
  .summary-cards .card.net{ grid-column:1 / -1; background:var(--glass-strong); }
  .summary-cards .card .lbl{ font-size:10.5px; text-transform:uppercase; letter-spacing:.06em; color:var(--text-faint); font-weight:700;}
  .summary-cards .card .val{ font-family:var(--font-num); font-size:19px; font-weight:700; margin-top:4px; color:var(--text); }
  .summary-cards .card.expense .val{ color:var(--expense); }
  .summary-cards .card.income .val{ color:var(--income); }

  .chart-card{ padding:16px; margin-bottom:18px; }
  .chart-card h3{ font-size:11.5px; text-transform:uppercase; letter-spacing:.06em; color:var(--text-soft); margin:0 0 10px; font-weight:700; }
  .empty-note{ font-size:12px; color:var(--text-faint); text-align:center; padding:20px 0; }

  .budget-card{ padding:14px; margin-bottom:10px; }
  .budget-card.over{ border-color:var(--warn); }
  .budget-card .top-row{ display:flex; justify-content:space-between; align-items:baseline; margin-bottom:8px; }
  .budget-card .name{ font-weight:700; font-size:12.5px; display:flex; align-items:center; gap:6px; }
  .budget-card .name svg{ width:14px; height:14px; stroke:var(--text-soft); }
  .budget-card .amounts{ font-family:var(--font-num); font-size:11.5px; color:var(--text-soft); }
  .budget-card .amounts b{ color:var(--text); }
  .bar-track{ height:7px; background:rgba(120,130,145,0.18); border-radius:99px; overflow:hidden; }
  .bar-fill{ height:100%; background:var(--income); border-radius:99px; transition:width .3s; }
  .bar-fill.over{ background:var(--warn); }
  .warn-line{ font-size:11px; color:var(--warn); font-weight:700; margin-top:6px; display:flex; gap:5px; align-items:center; }
  .warn-line svg{ width:13px; height:13px; stroke:var(--warn); }
  .del-x{ border:none; background:none; color:var(--text-faint); cursor:pointer; display:flex; }
  .del-x svg{ width:13px; height:13px; stroke:var(--text-faint); }

  .add-budget-form{ padding:14px; margin-top:6px; }
  .add-budget-form .row{ display:flex; gap:8px; margin-bottom:8px; }
  .add-budget-form select, .add-budget-form input{
    flex:1; padding:9px 10px; border-radius:11px; border:1px solid var(--glass-border); font-family:var(--font-ui); font-size:12px;
    background:var(--glass-strong); color:var(--text);
  }
  .add-budget-form button.save-budget{
    width:100%; padding:10px; border:none; border-radius:11px; background:var(--accent); color:var(--bg2); font-weight:700; cursor:pointer;
  }

  .settings-row{ display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid var(--glass-border); }
  .settings-row .lbl{ font-size:12.5px; font-weight:600; }
  .settings-row .val{ font-size:12px; color:var(--text-soft); font-family:var(--font-num); }
  .pill-btn{ border:1px solid var(--glass-border); background:var(--glass-strong); color:var(--accent); padding:6px 12px; border-radius:999px; font-size:11px; font-weight:700; cursor:pointer; display:inline-flex; align-items:center; gap:5px; }
  .pill-btn svg{ width:12px; height:12px; stroke:var(--accent); }
  .cat-manage-list{ display:flex; flex-wrap:wrap; gap:8px; margin-top:8px; }
  .cat-chip{ display:flex; align-items:center; gap:6px; background:var(--glass); backdrop-filter:blur(14px); border:1px solid var(--glass-border); padding:6px 10px; border-radius:999px; font-size:11.5px; }
  .cat-chip svg{ width:13px; height:13px; stroke:var(--text-soft); }
  .cat-chip button{ border:none; background:none; color:var(--text-faint); cursor:pointer; display:flex; }
  .cat-chip button svg{ width:11px; height:11px; stroke:var(--text-faint); }
  .add-cat-btn{ border:1px dashed var(--glass-border); background:none; padding:6px 12px; border-radius:999px; font-size:11.5px; color:var(--text-soft); cursor:pointer; }

  nav.tabbar{
    position:absolute; bottom:0; left:0; right:0; background:var(--glass-strong); backdrop-filter:blur(20px) saturate(180%);
    border-top:1px solid var(--glass-border); display:flex; padding:8px 10px 12px; z-index:5;
  }
  nav.tabbar button{ flex:1; border:none; background:none; display:flex; flex-direction:column; align-items:center; gap:4px; cursor:pointer; padding:6px 0; color:var(--text-faint); font-family:var(--font-ui); }
  nav.tabbar button svg{ width:19px; height:19px; stroke:var(--text-faint); }
  nav.tabbar button .txt{ font-size:10px; font-weight:700; }
  nav.tabbar button.active{ color:var(--text); }
  nav.tabbar button.active svg{ stroke:var(--accent); }

  .toast{
    position:absolute; top:16px; left:50%; transform:translateX(-50%); background:var(--glass-strong); backdrop-filter:blur(16px);
    border:1px solid var(--glass-border); color:var(--text); padding:10px 18px; border-radius:999px; font-size:12px; font-weight:600;
    opacity:0; pointer-events:none; transition:opacity .25s, top .25s; z-index:50;
  }
  .toast.show{ opacity:1; top:26px; }
  .hidden{ display:none !important; }

  .recent-list{ margin-top:4px; }
  .recent-item{ display:flex; justify-content:space-between; align-items:center; padding:10px 0; border-bottom:1px solid var(--glass-border); }
  .recent-item .left{ display:flex; align-items:center; gap:10px; }
  .recent-item .stamp-sm{ width:34px; height:34px; border-radius:11px; background:var(--glass); backdrop-filter:blur(14px); border:1px solid var(--glass-border); display:flex; align-items:center; justify-content:center;}
  .recent-item .stamp-sm svg{ width:15px; height:15px; stroke:var(--text-soft); }
  .recent-item .info .name{ font-size:12.5px; font-weight:600; }
  .recent-item .info .meta{ font-size:10.5px; color:var(--text-faint); }
  .recent-item .amt{ font-family:var(--font-num); font-weight:700; font-size:12.5px; }
  .recent-item .amt.expense{ color:var(--expense); }
  .recent-item .amt.income{ color:var(--income); }
  .recent-item .right{ display:flex; align-items:center; gap:8px; }
  .record-actions{ display:flex; gap:5px; }
  .mini-btn{ border:1px solid var(--glass-border); background:var(--glass); color:var(--text-soft); border-radius:999px; padding:5px 8px; font-size:10.5px; font-weight:700; cursor:pointer; }
  .mini-btn.danger{ color:var(--expense); }
  .edit-banner{ padding:10px 12px; margin-bottom:14px; display:flex; align-items:center; justify-content:space-between; gap:10px; font-size:12px; color:var(--accent); font-weight:700; }
  .chart-svg{ width:100%; height:auto; display:block; overflow:visible; }
  .chart-legend{ display:flex; flex-wrap:wrap; gap:8px 12px; margin-top:10px; }
  .legend-item{ display:flex; align-items:center; gap:5px; font-size:11px; color:var(--text-soft); }
  .legend-dot{ width:9px; height:9px; border-radius:99px; display:inline-block; }
  .chart-label{ font-family:var(--font-num); font-size:10px; fill:var(--text-soft); }
  .chart-line{ fill:none; stroke:var(--text); stroke-width:2.4; stroke-linecap:round; stroke-linejoin:round; }
  .budget-line{ fill:none; stroke:var(--accent); stroke-width:1.8; stroke-dasharray:5 4; }
  .chart-area{ fill:rgba(120,130,145,0.10); }
  .chart-point{ fill:var(--text); }
  .chart-point.over{ fill:var(--warn); }
  .modal-card{ max-height:86vh; overflow-y:auto; }
  .modal-icon-grid{ grid-template-columns:repeat(5,1fr); max-height:320px; overflow-y:auto; padding-right:2px; }

  .modal-overlay{
    position:absolute; inset:0; background:rgba(10,13,20,0.35); backdrop-filter:blur(4px); z-index:40;
    display:flex; align-items:center; justify-content:center; padding:20px;
  }
  .modal-card{ width:100%; max-width:340px; padding:20px; background:var(--glass-strong); backdrop-filter:blur(24px) saturate(180%); border:1px solid var(--glass-border); border-radius:20px; }
  .modal-title{ font-size:14px; font-weight:800; margin-bottom:14px; color:var(--text); }
  .modal-card input{ width:100%; padding:11px 13px; border-radius:12px; font-family:var(--font-ui); font-size:13px; margin-bottom:14px; background:var(--glass); border:1px solid var(--glass-border); color:var(--text); }
  .modal-icon-grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin-bottom:16px; }
  .modal-icon-grid .mi{ width:100%; aspect-ratio:1; border-radius:12px; background:var(--glass); border:1px solid var(--glass-border); display:flex; align-items:center; justify-content:center; cursor:pointer; }
  .modal-icon-grid .mi svg{ width:17px; height:17px; stroke:var(--text-soft); }
  .modal-icon-grid .mi.selected{ border-color:var(--accent); box-shadow:0 0 0 1px var(--accent) inset; }
  .modal-icon-grid .mi.selected svg{ stroke:var(--accent); }
  .modal-actions{ display:flex; gap:8px; }
  .modal-actions button{ flex:1; padding:11px; border-radius:12px; font-weight:700; font-size:12.5px; cursor:pointer; border:1px solid var(--glass-border); }
  .modal-actions .cancel{ background:var(--glass); color:var(--text-soft); }
  .modal-actions .save{ background:var(--accent); color:var(--bg2); border:none; }
</style>
</head>
<body>
<div id="shell">
  <header class="top">
    <div class="brand">
      <div class="mark"><svg class="ic" viewBox="0 0 24 24"><path d="M4 7h16M4 12h16M4 17h10"/></svg></div>
      <div>
        <h1>记账本</h1>
        <div class="sub" id="rateNote">加载中…</div>
      </div>
    </div>
    <div class="head-actions">
      <button class="icon-btn" id="themeToggle" aria-label="切换日夜模式"><svg class="ic" id="themeIcon" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg></button>
      <select id="countrySelect">
        <option value="CN">中国 · CNY</option>
        <option value="US">美国 · USD</option>
      </select>
    </div>
  </header>

  <main id="main"></main>

  <div class="toast" id="toast"></div>

  <div class="modal-overlay hidden" id="modalOverlay">
    <div class="modal-card">
      <div class="modal-title">新建类别</div>
      <input type="text" id="modalNameInput" placeholder="类别名称，例如：宠物">
      <div class="modal-icon-grid" id="modalIconGrid"></div>
      <div class="modal-actions">
        <button class="cancel" id="modalCancel">取消</button>
        <button class="save" id="modalSave">保存</button>
      </div>
    </div>
  </div>

  <input type="file" id="backupFile" accept="application/json,.json" class="hidden">

  <nav class="tabbar">
    <button data-tab="add" class="active"><svg class="ic" viewBox="0 0 24 24"><path d="M4 20h4L18.5 9.5a2.1 2.1 0 0 0-3-3L5 17v3z"/></svg><span class="txt">记一笔</span></button>
    <button data-tab="dashboard"><svg class="ic" viewBox="0 0 24 24"><path d="M5 20V11M11 20V6M17 20v-9M3 20h18"/></svg><span class="txt">Dashboard</span></button>
    <button data-tab="settings"><svg class="ic" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3.1"/><path d="M19.4 13a7.6 7.6 0 0 0 0-2l1.8-1.5-1.8-3.2-2.2.6a7.5 7.5 0 0 0-1.7-1L15 3.6h-4l-.5 2.3a7.5 7.5 0 0 0-1.7 1l-2.2-.6-1.8 3.2L6.6 11a7.6 7.6 0 0 0 0 2l-1.8 1.5 1.8 3.2 2.2-.6a7.5 7.5 0 0 0 1.7 1l.5 2.3h4l.5-2.3a7.5 7.5 0 0 0 1.7-1l2.2.6 1.8-3.2z"/></svg><span class="txt">设置</span></button>
  </nav>
</div>

<script>
const ICONS = {
  food:'<path d="M6 3v7a2 2 0 0 0 4 0V3M8 3v18M17 3c-2 0-3 2.5-3 5.5S15 13 17 13v8"/>',
  transport:'<path d="M5 17h14M5 17a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zM19 17a1.5 1.5 0 1 0 3 0 1.5 1.5 0 0 0-3 0zM3.5 17V11l2-5h9l3 5h2.5v6"/>',
  shopping:'<path d="M6 8h12l-1 12H7L6 8zM9 8a3 3 0 0 1 6 0"/>',
  fun:'<path d="M5 5h14v10H5zM9 19h6M5 15l4-4M19 15l-4-4"/>',
  housing:'<path d="M4 11l8-7 8 7M6 10v10h12V10"/>',
  medical:'<circle cx="12" cy="12" r="9"/><path d="M12 8v8M8 12h8"/>',
  edu:'<path d="M4 6h7v14H4zM20 6h-7v14h7z"/>',
  other:'<path d="M12 3l8 4.5v9L12 21l-8-4.5v-9z"/>',
  salary:'<path d="M4 9h16v10H4zM9 9V6a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v3"/>',
  bonus:'<rect x="4" y="9" width="16" height="10"/><path d="M4 9h16M12 9v10M9 9c-1.5-3 1.5-4 3-1M15 9c1.5-3-1.5-4-3 1"/>',
  invest:'<path d="M4 17l5-5 4 4 7-8M14 8h6v6"/>',
  grocery:'<path d="M5 6h2l1.5 10h9l1.5-7H8"/><circle cx="10" cy="20" r="1"/><circle cx="17" cy="20" r="1"/>',
  coffee:'<path d="M5 8h11v6a4 4 0 0 1-4 4H9a4 4 0 0 1-4-4z"/><path d="M16 10h2a2 2 0 0 1 0 4h-2M7 4v2M11 4v2M15 4v2"/>',
  pet:'<circle cx="7" cy="8" r="1.5"/><circle cx="12" cy="6" r="1.5"/><circle cx="17" cy="8" r="1.5"/><path d="M7 16c1.5-4 8.5-4 10 0 1 2-1 4-3 3l-2-1-2 1c-2 1-4-1-3-3z"/>',
  baby:'<circle cx="12" cy="8" r="3"/><path d="M6 21c.8-4 3-6 6-6s5.2 2 6 6M9 9h.01M15 9h.01"/>',
  gift:'<rect x="4" y="8" width="16" height="12"/><path d="M12 8v12M4 12h16M9 8c-2-2-1-4 1-4 1.5 0 2 2 2 4M15 8c2-2 1-4-1-4-1.5 0-2 2-2 4"/>',
  travel:'<path d="M3 16l18-8-7 11-3-5-5 4z"/>',
  flight:'<path d="M2 16l20-8-8 12-3-6-5 4z"/>',
  train:'<rect x="6" y="3" width="12" height="14" rx="2"/><path d="M8 8h8M9 17l-2 3M15 17l2 3M9 13h.01M15 13h.01"/>',
  car:'<path d="M4 15h16M6 15l2-5h8l2 5M7 18h.01M17 18h.01"/>',
  phone:'<rect x="8" y="3" width="8" height="18" rx="2"/><path d="M11 18h2"/>',
  utilities:'<path d="M13 2L5 14h6l-1 8 8-12h-6z"/>',
  internet:'<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c3 3.2 3 14.8 0 18M12 3c-3 3.2-3 14.8 0 18"/>',
  insurance:'<path d="M12 3l7 3v5c0 5-3 8-7 10-4-2-7-5-7-10V6z"/><path d="M9 12l2 2 4-4"/>',
  tax:'<path d="M6 3h9l3 3v15H6z"/><path d="M14 3v4h4M8 12h8M8 16h5"/>',
  book:'<path d="M5 4h7a3 3 0 0 1 3 3v13a3 3 0 0 0-3-3H5zM19 4h-4a3 3 0 0 0-3 3"/>',
  sport:'<circle cx="12" cy="12" r="9"/><path d="M5 8c5 2 9 6 11 11M19 8c-5 2-9 6-11 11"/>',
  beauty:'<path d="M7 21h10M9 21V9a3 3 0 0 1 6 0v12M10 5h4"/>',
  clothes:'<path d="M8 4l-4 3 3 4 1-1v10h8V10l1 1 3-4-4-3-2 2h-4z"/>',
  repair:'<path d="M14 6l4 4M16 4l4 4-10 10H6v-4z"/>',
  cash:'<rect x="3" y="7" width="18" height="10" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 10v4M18 10v4"/>',
  bank:'<path d="M3 9l9-5 9 5zM5 9v9M9 9v9M15 9v9M19 9v9M4 18h16M3 21h18"/>',
  wallet:'<path d="M4 7h15v12H4z"/><path d="M16 11h5v4h-5a2 2 0 0 1 0-4zM4 7l11-3 2 3"/>',
  camera:'<path d="M4 8h3l1.5-2h7L17 8h3v11H4z"/><circle cx="12" cy="13.5" r="3.2"/>',
  refresh:'<path d="M20 12a8 8 0 1 1-2.34-5.66M20 4v5h-5"/>',
  warn:'<path d="M12 4l9 16H3z"/><path d="M12 10.3v3.6M12 17h.01"/>',
  x:'<path d="M6 6l12 12M18 6L6 18"/>',
  chevL:'<path d="M15 6l-6 6 6 6"/>',
  chevR:'<path d="M9 6l6 6-6 6"/>',
  clock:'<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>'
};
function svgIcon(key, cls){ return '<svg class="ic '+(cls||'')+'" viewBox="0 0 24 24">'+(ICONS[key]||ICONS.other)+'</svg>'; }
const EXPENSE_ICON_KEYS = ['food','grocery','coffee','transport','car','train','flight','travel','shopping','clothes','fun','sport','housing','utilities','internet','medical','insurance','edu','book','pet','baby','beauty','gift','repair','tax','phone','other'];
const INCOME_ICON_KEYS = ['salary','bonus','invest','cash','bank','wallet','gift','other'];

const DEFAULT_CATEGORIES = {
  expense: [
    {id:'food', name:'餐饮', icon:'food'}, {id:'transport', name:'交通', icon:'transport'},
    {id:'shopping', name:'购物', icon:'shopping'}, {id:'fun', name:'娱乐', icon:'fun'},
    {id:'housing', name:'住房', icon:'housing'}, {id:'medical', name:'医疗', icon:'medical'},
    {id:'edu', name:'教育', icon:'edu'}, {id:'other_e', name:'其他', icon:'other'}
  ],
  income: [
    {id:'salary', name:'工资', icon:'salary'}, {id:'bonus', name:'奖金', icon:'bonus'},
    {id:'invest', name:'投资', icon:'invest'}, {id:'other_i', name:'其他', icon:'other'}
  ]
};
let state = {
  settings: { country:'CN', baseCurrency:'CNY', theme:'light', rate:{ CNYperUSD:7.2, updatedAt:null } },
  categories: JSON.parse(JSON.stringify(DEFAULT_CATEGORIES)),
  transactions: [],
  budgets: []
};
let ui = {
  tab:'add', type:'expense',
  selectedCat: 'food', selectedIncomeCat:'salary',
  entryCurrency:'CNY',
  dashPeriod:'month', dashOffset:0,
  ocrLoading:false, receiptImg:null,
  modalType:null, modalIcon:'other', editingId:null, editAmount:'', editVendor:'', editDate:''
};
let pieChart=null, lineChart=null;

const STORAGE_PREFIX = 'family-ledger:';
const SNAPSHOT_KEY = STORAGE_PREFIX + 'snapshot';
function readLocalJSON(key, fallback){
  try{
    // Prefer the stable namespaced key. Also read the old un-prefixed key for migration.
    const raw = localStorage.getItem(STORAGE_PREFIX + key) || localStorage.getItem(key);
    return raw ? JSON.parse(raw) : fallback;
  }catch(e){
    console.warn('读取本地数据失败:', key, e);
    return fallback;
  }
}
function buildSnapshot(){
  return {
    app:'family-ledger-pwa', version:3, exportedAt:new Date().toISOString(),
    settings:state.settings, categories:state.categories, transactions:state.transactions, budgets:state.budgets
  };
}
function writeSnapshot(){
  try{ localStorage.setItem(SNAPSHOT_KEY, JSON.stringify(buildSnapshot())); }catch(e){}
}
function restoreFromSnapshotIfNeeded(){
  if(state.transactions.length || state.budgets.length) return;
  try{
    const raw = localStorage.getItem(SNAPSHOT_KEY);
    if(!raw) return;
    const backup = JSON.parse(raw);
    if(backup && Array.isArray(backup.transactions) && backup.transactions.length){
      state.settings = Object.assign(state.settings, backup.settings || {});
      state.categories = backup.categories || state.categories;
      state.transactions = backup.transactions || [];
      state.budgets = backup.budgets || [];
      toast('已从本机缓存恢复账本');
    }
  }catch(e){ console.warn('自动恢复失败:', e); }
}
async function loadState(){
  state.settings = Object.assign(state.settings, readLocalJSON('settings', {}));
  state.categories = readLocalJSON('categories', state.categories);
  state.transactions = readLocalJSON('transactions', state.transactions);
  state.budgets = readLocalJSON('budgets', state.budgets);
  restoreFromSnapshotIfNeeded();
  ui.entryCurrency = state.settings.baseCurrency;
  document.getElementById('countrySelect').value = state.settings.country;
  applyTheme();
}
async function persist(key, val){
  try{
    localStorage.setItem(STORAGE_PREFIX + key, JSON.stringify(val));
    writeSnapshot();
  }catch(e){
    console.error('save failed', key, e);
    toast('保存失败，可能是浏览器存储空间不足');
  }
}
async function saveSettings(){ await persist('settings', state.settings); }
async function saveCategories(){ await persist('categories', state.categories); }
async function saveTransactions(){ await persist('transactions', state.transactions); }
async function saveBudgets(){ await persist('budgets', state.budgets); }

function applyTheme(){
  const shell = document.getElementById('shell');
  const dark = state.settings.theme==='dark';
  shell.classList.toggle('dark', dark);
  document.body.classList.toggle('dark-bg', dark);
  document.getElementById('themeIcon').innerHTML = dark
    ? '<path d="M20 14.5A8.5 8.5 0 1 1 9.5 4a7 7 0 0 0 10.5 10.5z"/>'
    : '<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/>';
}
document.getElementById('themeToggle').onclick = async ()=>{
  state.settings.theme = state.settings.theme==='dark' ? 'light':'dark';
  applyTheme();
  await saveSettings();
  if(ui.tab==='dashboard') renderDashboardCharts();
};

async function fetchJSONWithTimeout(url, ms){
  const controller = new AbortController();
  const timer = setTimeout(()=>controller.abort(), ms || 6000);
  try{
    const res = await fetch(url, { cache:'no-store', signal:controller.signal });
    if(!res.ok) throw new Error('HTTP '+res.status);
    return await res.json();
  }finally{ clearTimeout(timer); }
}
async function refreshRate(showToast){
  document.getElementById('rateNote').textContent = '正在获取汇率…';
  const sources = [
    {name:'Frankfurter', url:'https://api.frankfurter.app/latest?from=USD&to=CNY', read:d=>d && d.rates && d.rates.CNY},
    {name:'Open ER API', url:'https://open.er-api.com/v6/latest/USD', read:d=>d && d.rates && d.rates.CNY},
    {name:'ExchangeRate API', url:'https://api.exchangerate-api.com/v4/latest/USD', read:d=>d && d.rates && d.rates.CNY}
  ];
  let lastError = null;
  for(const source of sources){
    try{
      const data = await fetchJSONWithTimeout(source.url, 7000);
      const rate = Number(source.read(data));
      if(rate && rate>0){
        state.settings.rate = { CNYperUSD:rate, updatedAt:new Date().toISOString(), source:source.name };
        await saveSettings();
        renderRateNote();
        if(showToast) toast('汇率已更新：'+source.name);
        return true;
      }
    }catch(e){ lastError = e; }
  }
  console.warn('汇率刷新失败:', lastError);
  renderRateNote();
  toast('汇率刷新失败，已保留上次汇率');
  return false;
}
function renderRateNote(){
  const r = state.settings.rate;
  const t = r.updatedAt ? new Date(r.updatedAt).toLocaleString('zh-CN',{month:'numeric',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '默认值';
  document.getElementById('rateNote').textContent = '1 USD ≈ '+r.CNYperUSD.toFixed(3)+' CNY · '+t+(r.source?' · '+r.source:'');
}
function convert(amount, from, to){
  if(from===to) return amount;
  const rate = state.settings.rate.CNYperUSD;
  if(from==='USD' && to==='CNY') return amount*rate;
  if(from==='CNY' && to==='USD') return amount/rate;
  return amount;
}

function toast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 1800);
}
function detectTZNote(){
  try{ return { tz: Intl.DateTimeFormat().resolvedOptions().timeZone || '本地时区' }; }catch(e){ return {tz:'本地时区'}; }
}

function render(){
  document.querySelectorAll('nav.tabbar button').forEach(b=>b.classList.toggle('active', b.dataset.tab===ui.tab));
  const main = document.getElementById('main');
  if(ui.tab==='add') main.innerHTML = renderAddTab();
  else if(ui.tab==='dashboard') main.innerHTML = renderDashboardTab();
  else main.innerHTML = renderSettingsTab();
  attachHandlers();
  if(ui.tab==='dashboard') renderDashboardCharts();
}

function escapeAttr(val){
  return String(val ?? '').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;');
}
function isoToLocalInput(iso){
  const d = iso ? new Date(iso) : new Date();
  if(isNaN(d.getTime())) return nowLocalISO();
  d.setMinutes(d.getMinutes()-d.getTimezoneOffset());
  return d.toISOString().slice(0,16);
}
function renderEditBanner(){
  if(!ui.editingId) return '';
  return '<div class="edit-banner glass"><span>正在修改一笔记录</span><button class="mini-btn" data-action="cancel-edit">取消修改</button></div>';
}
function renderDateRow(value){
  const tzInfo = detectTZNote();
  return '<h2 class="section-title">时间</h2>'+ 
    '<div class="datetime-row glass">'+
      '<input type="datetime-local" id="txDate" value="'+value+'">'+
      '<span class="tz-note">'+svgIcon('clock')+tzInfo.tz+'</span>'+
    '</div>';
}
function renderAddTab(){
  const isExpense = ui.type==='expense';
  const cats = isExpense ? state.categories.expense : state.categories.income;
  const selected = isExpense ? ui.selectedCat : ui.selectedIncomeCat;
  const dateValue = ui.editDate || nowLocalISO();
  const amountValue = ui.editAmount || (isExpense ? (ui.lastAmount||'') : '');
  const vendorValue = ui.editVendor || (ui.lastVendor||'');
  const submitText = ui.editingId ? '保存修改' : (isExpense ? '提交支出' : '提交收入');

  let html = renderEditBanner()+
  '<div class="segmented">'+
    '<button data-action="set-type" data-val="expense" class="'+(isExpense?'active expense-active':'')+'">支出 Expense</button>'+
    '<button data-action="set-type" data-val="income" class="'+(!isExpense?'active income-active':'')+'">收入 Income</button>'+
  '</div>';

  if(isExpense){
    html += renderDateRow(dateValue)+
    '<h2 class="section-title">类别</h2>'+ 
    '<div class="cat-grid" id="catGrid">'+
      cats.map(c=>'<div class="cat-item '+(c.id===selected?'selected':'')+'" data-action="pick-cat" data-id="'+c.id+'"><div class="stamp">'+svgIcon(c.icon)+'</div><span class="lbl">'+c.name+'</span></div>').join('')+
      '<div class="cat-item add-new" data-action="add-cat" data-type="expense"><div class="stamp"><span style="font-size:20px;color:var(--text-faint);line-height:0;">+</span></div><span class="lbl">添加</span></div>'+ 
    '</div>'+ 
    '<h2 class="section-title">账单照片 (OCR自动识别)</h2>'+ 
    '<div class="receipt-drop glass '+(ui.receiptImg?'has-image':'')+'" id="receiptDrop">'+
      (ui.receiptImg ? '<img src="'+ui.receiptImg+'">' : svgIcon('camera')+'<div class="hint"><b>点击上传</b>或拍照账单<br>自动识别金额与商家</div>')+
    '</div>'+ 
    '<input type="file" id="receiptFile" accept="image/*" class="hidden">'+
    (ui.ocrLoading ? '<div class="ocr-bar"><div class="spinner"></div>识别中，请稍候…</div>' : '')+
    '<div class="field"><label>商家 Vendor</label><input type="text" id="vendorInput" placeholder="例如：星巴克" value="'+escapeAttr(vendorValue)+'"></div>'+ 
    '<div class="field"><label>金额 Amount</label>'+ 
      '<div class="amount-row">'+
        '<input type="number" id="amountInput" placeholder="0.00" step="0.01" value="'+escapeAttr(amountValue)+'">'+
        '<div class="cur-toggle">'+
          '<button data-action="set-cur" data-val="CNY" class="'+(ui.entryCurrency==='CNY'?'active':'')+'">CNY</button>'+ 
          '<button data-action="set-cur" data-val="USD" class="'+(ui.entryCurrency==='USD'?'active':'')+'">USD</button>'+ 
        '</div>'+ 
      '</div>'+ 
      '<div class="convert-note" id="convertNote"></div>'+ 
    '</div>'+ 
    '<button class="submit-btn expense-btn" data-action="submit-expense">'+submitText+'</button>';
  } else {
    html += renderDateRow(dateValue)+
    '<h2 class="section-title">类别</h2>'+ 
    '<div class="cat-grid">'+
      cats.map(c=>'<div class="cat-item '+(c.id===selected?'selected':'')+'" data-action="pick-income-cat" data-id="'+c.id+'"><div class="stamp">'+svgIcon(c.icon)+'</div><span class="lbl">'+c.name+'</span></div>').join('')+
      '<div class="cat-item add-new" data-action="add-cat" data-type="income"><div class="stamp"><span style="font-size:20px;color:var(--text-faint);line-height:0;">+</span></div><span class="lbl">添加</span></div>'+ 
    '</div>'+ 
    '<div class="field"><label>金额 Amount</label>'+ 
      '<div class="amount-row">'+
        '<input type="number" id="amountInputIncome" placeholder="0.00" step="0.01" value="'+escapeAttr(amountValue)+'">'+
        '<div class="cur-toggle">'+
          '<button data-action="set-cur" data-val="CNY" class="'+(ui.entryCurrency==='CNY'?'active':'')+'">CNY</button>'+ 
          '<button data-action="set-cur" data-val="USD" class="'+(ui.entryCurrency==='USD'?'active':'')+'">USD</button>'+ 
        '</div>'+ 
      '</div>'+ 
    '</div>'+ 
    '<button class="submit-btn income-btn" data-action="submit-income">'+submitText+'</button>';
  }
  html += renderRecentList();
  return html;
}

function renderRecentList(){
  const recent = [...state.transactions].sort((a,b)=>new Date(b.date)-new Date(a.date)).slice(0,12);
  if(recent.length===0) return '';
  let rows = recent.map(t=>{
    const catList = t.type==='expense'?state.categories.expense:state.categories.income;
    const cat = catList.find(c=>c.id===t.categoryId) || {icon:'other',name:t.categoryId};
    const d = new Date(t.date);
    const dLabel = d.toLocaleDateString('zh-CN',{month:'numeric',day:'numeric'});
    const title = t.vendor || cat.name;
    return '<div class="recent-item">'+
      '<div class="left"><div class="stamp-sm">'+svgIcon(cat.icon)+'</div><div class="info"><div class="name">'+escapeAttr(title)+'</div><div class="meta">'+dLabel+' · '+cat.name+' · '+t.currency+'</div></div></div>'+ 
      '<div class="right"><div class="amt '+t.type+'">'+(t.type==='expense'?'-':'+')+(t.currency==='CNY'?'¥':'$')+t.amount.toFixed(2)+'</div>'+ 
      '<div class="record-actions"><button class="mini-btn" data-action="edit-tx" data-id="'+t.id+'">编辑</button><button class="mini-btn danger" data-action="delete-tx" data-id="'+t.id+'">删除</button></div></div>'+ 
    '</div>';
  }).join('');
  return '<h2 class="section-title">最近记录</h2><div class="recent-list">'+rows+'</div>';
}

function nowLocalISO(){
  const d = new Date();
  d.setMinutes(d.getMinutes()-d.getTimezoneOffset());
  return d.toISOString().slice(0,16);
}

function getPeriodRange(period, offset){
  const now = new Date();
  let start, end, label;
  if(period==='day'){
    start = new Date(now); start.setDate(start.getDate()+offset); start.setHours(0,0,0,0);
    end = new Date(start); end.setDate(end.getDate()+1);
    label = start.toLocaleDateString('zh-CN',{month:'long',day:'numeric',weekday:'short'});
  } else if(period==='week'){
    const day = now.getDay()===0?7:now.getDay();
    start = new Date(now); start.setDate(start.getDate()-day+1+offset*7); start.setHours(0,0,0,0);
    end = new Date(start); end.setDate(end.getDate()+7);
    label = (start.getMonth()+1)+'/'+start.getDate()+' - '+(new Date(end-1).getMonth()+1)+'/'+new Date(end-1).getDate();
  } else if(period==='month'){
    start = new Date(now.getFullYear(), now.getMonth()+offset, 1);
    end = new Date(now.getFullYear(), now.getMonth()+offset+1, 1);
    label = start.toLocaleDateString('zh-CN',{year:'numeric',month:'long'});
  } else if(period==='quarter'){
    const q = Math.floor(now.getMonth()/3)+offset;
    start = new Date(now.getFullYear(), q*3, 1);
    end = new Date(now.getFullYear(), q*3+3, 1);
    label = start.getFullYear()+'年 Q'+(Math.floor(start.getMonth()/3)+1);
  } else {
    start = new Date(now.getFullYear()+offset, 0, 1);
    end = new Date(now.getFullYear()+offset+1, 0, 1);
    label = start.getFullYear()+'年';
  }
  return {start, end, label};
}
function txInRange(start,end){ return state.transactions.filter(t=>{ const d=new Date(t.date); return d>=start && d<end; }); }
function amountInBase(t){ return convert(t.amount, t.currency, state.settings.baseCurrency); }
function currencySymbol(){ return state.settings.baseCurrency==='CNY' ? '¥' : '$'; }

function renderDashboardTab(){
  const {start,end,label} = getPeriodRange(ui.dashPeriod, ui.dashOffset);
  const txns = txInRange(start,end);
  const income = txns.filter(t=>t.type==='income').reduce((s,t)=>s+amountInBase(t),0);
  const expense = txns.filter(t=>t.type==='expense').reduce((s,t)=>s+amountInBase(t),0);
  const net = income-expense;
  const sym = currencySymbol();

  const periodBtns = ['day','week','month','quarter','year'].map(p=>{
    const lbl = {day:'日',week:'周',month:'月',quarter:'季',year:'年'}[p];
    return '<button data-action="set-period" data-val="'+p+'" class="'+(ui.dashPeriod===p?'active':'')+'">'+lbl+'</button>';
  }).join('');

  let html = ''+
  '<div class="period-bar">'+periodBtns+'</div>'+
  '<div class="period-nav"><button data-action="nav-period" data-val="-1">'+svgIcon('chevL')+'</button><div class="label">'+label+'</div><button data-action="nav-period" data-val="1">'+svgIcon('chevR')+'</button></div>'+
  '<div class="summary-cards">'+
    '<div class="card glass expense"><div class="lbl">支出</div><div class="val">'+sym+expense.toFixed(2)+'</div></div>'+
    '<div class="card glass income"><div class="lbl">收入</div><div class="val">'+sym+income.toFixed(2)+'</div></div>'+
    '<div class="card glass net"><div class="lbl">结余</div><div class="val" style="color:'+(net>=0?'var(--income)':'var(--expense)')+'">'+(net>=0?'+':'')+sym+net.toFixed(2)+'</div></div>'+
  '</div>'+
  '<div class="chart-card glass"><h3>支出分类占比</h3><div id="pieChartBox"></div><div id="pieEmpty"></div></div>'+
  '<h2 class="section-title">预算 Budget</h2>'+
  '<div id="budgetList">'+renderBudgetCards()+'</div>'+
  '<div class="add-budget-form glass">'+
    '<div class="row">'+
      '<select id="budgetPeriod"><option value="day">按天</option><option value="week">按周</option><option value="month" selected>按月</option></select>'+
      '<select id="budgetCategory"><option value="">总预算 (全部类别)</option>'+state.categories.expense.map(c=>'<option value="'+c.id+'">'+c.name+'</option>').join('')+'</select>'+
    '</div>'+
    '<div class="row"><input type="number" id="budgetAmount" placeholder="预算金额 ('+state.settings.baseCurrency+')" step="0.01"></div>'+
    '<button class="save-budget" data-action="add-budget">设定预算</button>'+
  '</div>'+
  '<div class="chart-card glass" style="margin-top:16px;"><h3>本期预算趋势 ('+({day:'日',week:'周',month:'月'}[ui.dashPeriod]||'月')+')</h3><div id="lineChartBox"></div><div id="lineEmpty"></div></div>';
  return html;
}

function renderBudgetCards(){
  if(state.budgets.length===0) return '<div class="empty-note">还没有设定预算，在下方添加一个吧</div>';
  return state.budgets.map(b=>{
    const {start:bs, end:be} = getPeriodRange(b.period, 0);
    const relevant = txInRange(bs,be).filter(t=>t.type==='expense' && (!b.category || t.categoryId===b.category));
    const spent = relevant.reduce((s,t)=>s+amountInBase(t),0);
    const pct = Math.min(100, (spent/b.amount)*100);
    const over = spent > b.amount;
    const catObj = b.category ? state.categories.expense.find(c=>c.id===b.category) : null;
    const sym = currencySymbol();
    const periodLbl = {day:'每日',week:'每周',month:'每月'}[b.period];
    return '<div class="budget-card glass '+(over?'over':'')+'">'+
      '<div class="top-row"><div class="name">'+svgIcon(catObj?catObj.icon:'invest')+' '+(catObj?catObj.name:'总预算')+' · '+periodLbl+'</div><button class="del-x" data-action="del-budget" data-id="'+b.id+'">'+svgIcon('x')+'</button></div>'+
      '<div class="amounts">已花 <b>'+sym+spent.toFixed(2)+'</b> / 预算 <b>'+sym+b.amount.toFixed(2)+'</b></div>'+
      '<div class="bar-track"><div class="bar-fill '+(over?'over':'')+'" style="width:'+pct+'%"></div></div>'+
      (over ? '<div class="warn-line">'+svgIcon('warn')+'已超出预算 '+sym+(spent-b.amount).toFixed(2)+'</div>' : '')+
    '</div>';
  }).join('');
}

function chartTextColor(){ return state.settings.theme==='dark' ? '#9EA3BC' : '#647486'; }
function chartPalette(){
  return state.settings.theme==='dark'
    ? ['#D4AF5A','#8FA6C9','#6E7FA6','#B98F4B','#7A99A6','#9C8C6E','#5C7A99','#C9A65C','#A67A7A','#6FA68A','#A6A06F','#8A6FA6']
    : ['#3E6D9C','#7CA6C9','#2C4A66','#B98F4B','#5C7A8C','#8C6E9C','#4B7A6E','#A65C4B','#6D9C3E','#9C3E6D','#6D3E9C','#9C6D3E'];
}
function polarToCartesian(cx, cy, r, angle){
  const rad = (angle - 90) * Math.PI / 180;
  return { x: cx + r * Math.cos(rad), y: cy + r * Math.sin(rad) };
}
function donutSlicePath(cx, cy, rOuter, rInner, startAngle, endAngle){
  const largeArc = endAngle - startAngle > 180 ? 1 : 0;
  const p1 = polarToCartesian(cx, cy, rOuter, endAngle);
  const p2 = polarToCartesian(cx, cy, rOuter, startAngle);
  const p3 = polarToCartesian(cx, cy, rInner, startAngle);
  const p4 = polarToCartesian(cx, cy, rInner, endAngle);
  return ['M',p1.x,p1.y,'A',rOuter,rOuter,0,largeArc,0,p2.x,p2.y,'L',p3.x,p3.y,'A',rInner,rInner,0,largeArc,1,p4.x,p4.y,'Z'].join(' ');
}
function renderDonutChart(rows){
  const total = rows.reduce((s,r)=>s+r.value,0);
  const colors = chartPalette();
  let angle = 0;
  const slices = rows.map((r,i)=>{
    const next = angle + (r.value/total)*360;
    const path = donutSlicePath(110,110,92,55,angle,next);
    angle = next;
    return '<path d="'+path+'" fill="'+colors[i%colors.length]+'"></path>';
  }).join('');
  const legend = rows.map((r,i)=>'<span class="legend-item"><span class="legend-dot" style="background:'+colors[i%colors.length]+'"></span>'+r.label+' '+Math.round(r.value/total*100)+'%</span>').join('');
  return '<svg class="chart-svg" viewBox="0 0 220 220" aria-label="支出分类占比">'+slices+
    '<text x="110" y="104" text-anchor="middle" class="chart-label">总支出</text>'+ 
    '<text x="110" y="126" text-anchor="middle" style="font-family:var(--font-num);font-size:18px;font-weight:700;fill:var(--text);">'+currencySymbol()+total.toFixed(0)+'</text>'+ 
    '</svg><div class="chart-legend">'+legend+'</div>';
}
function renderLineChart(labels, spentData, budgetAmount){
  const w=320, h=190, padL=36, padR=12, padT=16, padB=28;
  const maxVal = Math.max(budgetAmount||0, ...spentData, 1) * 1.15;
  const plotW = w-padL-padR, plotH = h-padT-padB;
  const x = i => padL + (spentData.length===1 ? plotW/2 : i*plotW/(spentData.length-1));
  const y = v => padT + plotH - (v/maxVal)*plotH;
  const pts = spentData.map((v,i)=>[x(i),y(v)]);
  const line = pts.map((p,i)=>(i?'L':'M')+p[0].toFixed(1)+' '+p[1].toFixed(1)).join(' ');
  const area = line + ' L '+x(spentData.length-1).toFixed(1)+' '+(padT+plotH)+' L '+x(0).toFixed(1)+' '+(padT+plotH)+' Z';
  const budgetY = y(budgetAmount||0);
  const circles = pts.map((p,i)=>'<circle class="chart-point '+(spentData[i]>(budgetAmount||Infinity)?'over':'')+'" cx="'+p[0].toFixed(1)+'" cy="'+p[1].toFixed(1)+'" r="3.5"></circle>').join('');
  const tickIdx = Array.from(new Set([0, Math.floor((labels.length-1)/2), labels.length-1])).filter(i=>i>=0);
  const xLabels = tickIdx.map(i=>'<text x="'+x(i).toFixed(1)+'" y="178" text-anchor="middle" class="chart-label">'+labels[i]+'</text>').join('');
  const yTop = '<text x="4" y="'+(padT+4)+'" class="chart-label">'+currencySymbol()+Math.round(maxVal)+'</text>';
  const yZero = '<text x="8" y="'+(padT+plotH+4)+'" class="chart-label">0</text>';
  return '<svg class="chart-svg" viewBox="0 0 '+w+' '+h+'" aria-label="本期预算趋势">'+
    '<path d="M'+padL+' '+padT+' V'+(padT+plotH)+' H'+(w-padR)+'" fill="none" stroke="rgba(120,130,145,0.22)"/>'+ 
    '<path class="chart-area" d="'+area+'"></path><path class="chart-line" d="'+line+'"></path>'+ 
    (budgetAmount ? '<path class="budget-line" d="M'+padL+' '+budgetY.toFixed(1)+' H'+(w-padR)+'"></path>' : '')+
    circles + xLabels + yTop + yZero + '</svg>'+ 
    '<div class="chart-legend"><span class="legend-item"><span class="legend-dot" style="background:var(--text)"></span>累计支出</span><span class="legend-item"><span class="legend-dot" style="background:var(--accent)"></span>预算上限</span></div>';
}
function renderDashboardCharts(){
  const {start,end} = getPeriodRange(ui.dashPeriod, ui.dashOffset);
  const txns = txInRange(start,end).filter(t=>t.type==='expense');
  const byCat = {};
  txns.forEach(t=>{ byCat[t.categoryId] = (byCat[t.categoryId]||0) + amountInBase(t); });
  const pieBox = document.getElementById('pieChartBox');
  const pieEmpty = document.getElementById('pieEmpty');
  if(!pieBox) return;
  const rows = Object.keys(byCat).map(id=>{ const c=state.categories.expense.find(c=>c.id===id); return { label:c?c.name:id, value:byCat[id] }; }).sort((a,b)=>b.value-a.value);
  if(rows.length===0){
    pieBox.innerHTML = '';
    pieEmpty.innerHTML = '<div class="empty-note">本期还没有支出记录</div>';
  } else {
    pieEmpty.innerHTML = '';
    pieBox.innerHTML = renderDonutChart(rows);
  }

  const period = ['day','week','month'].includes(ui.dashPeriod) ? ui.dashPeriod : 'month';
  const budget = state.budgets.find(b=>b.period===period && !b.category) || state.budgets.find(b=>b.period===period);
  const lineBox = document.getElementById('lineChartBox');
  const lineEmpty = document.getElementById('lineEmpty');
  if(!lineBox) return;
  const {start:bs, end:be} = getPeriodRange(period, ui.dashPeriod===period ? ui.dashOffset : 0);
  const dayMs = 24*60*60*1000;
  const totalDays = Math.max(1, Math.round((be-bs)/dayMs));
  const now = new Date();
  const maxEnd = now < bs ? bs : (now > be ? be : now);
  const daysShown = Math.min(totalDays, Math.max(1, Math.floor((maxEnd-bs)/dayMs)+1));
  let cum = 0; const cumData=[]; const labels=[];
  for(let i=0;i<daysShown;i++){
    const dayStart = new Date(bs.getTime()+i*dayMs);
    const dayEnd = new Date(dayStart.getTime()+dayMs);
    const spentDay = txInRange(dayStart,dayEnd).filter(t=>t.type==='expense' && (!budget || !budget.category || t.categoryId===budget.category)).reduce((sum,t)=>sum+amountInBase(t),0);
    cum += spentDay;
    cumData.push(cum);
    labels.push((dayStart.getMonth()+1)+'/'+dayStart.getDate());
  }
  const budgetAmount = budget ? budget.amount : 0;
  if(cumData.every(v=>v===0) && !budget){
    lineBox.innerHTML = '';
    lineEmpty.innerHTML = '<div class="empty-note">本期还没有支出记录；添加支出后这里会显示累计趋势</div>';
  } else {
    lineBox.innerHTML = renderLineChart(labels, cumData, budgetAmount);
    const overIdx = budget ? cumData.findIndex(v=>v>budget.amount) : -1;
    if(!budget){
      lineEmpty.innerHTML = '<div class="empty-note">未设置预算；当前显示本期累计支出趋势</div>';
    } else if(overIdx>=0){
      lineEmpty.innerHTML = '<div class="warn-line" style="margin-top:8px;">'+svgIcon('warn')+'已于 '+labels[overIdx]+' 超出预算</div>';
    } else {
      lineEmpty.innerHTML = '';
    }
  }
}

function renderSettingsTab(){
  const r = state.settings.rate;
  return ''+
  '<h2 class="section-title">国家 / 基准货币</h2>'+
  '<div class="settings-row"><div class="lbl">当前国家</div><div class="val">'+(state.settings.country==='CN'?'中国 (CNY)':'美国 (USD)')+'</div></div>'+
  '<h2 class="section-title">外观</h2>'+
  '<div class="settings-row"><div class="lbl">主题模式</div><button class="pill-btn" data-action="toggle-theme-settings">'+(state.settings.theme==='dark'?'夜间 · 切换为日间':'日间 · 切换为夜间')+'</button></div>'+
  '<h2 class="section-title">汇率</h2>'+
  '<div class="settings-row"><div class="lbl">USD → CNY</div><div class="val">'+r.CNYperUSD.toFixed(4)+'</div></div>'+
  '<div class="settings-row"><div class="lbl">更新时间</div><div class="val">'+(r.updatedAt ? new Date(r.updatedAt).toLocaleString('zh-CN') : '默认值，未联网更新')+'</div></div>'+
  '<div style="margin-top:10px;"><button class="pill-btn" data-action="refresh-rate">'+svgIcon('refresh')+'刷新汇率</button></div>'+
  '<h2 class="section-title">支出类别</h2>'+
  '<div class="cat-manage-list">'+
    state.categories.expense.map(c=>'<div class="cat-chip">'+svgIcon(c.icon)+c.name+' '+(c.custom?'<button data-action="del-cat" data-type="expense" data-id="'+c.id+'">'+svgIcon('x')+'</button>':'')+'</div>').join('')+
    '<button class="add-cat-btn" data-action="add-cat" data-type="expense">+ 添加类别</button>'+
  '</div>'+
  '<h2 class="section-title">收入类别</h2>'+
  '<div class="cat-manage-list">'+
    state.categories.income.map(c=>'<div class="cat-chip">'+svgIcon(c.icon)+c.name+' '+(c.custom?'<button data-action="del-cat" data-type="income" data-id="'+c.id+'">'+svgIcon('x')+'</button>':'')+'</div>').join('')+
    '<button class="add-cat-btn" data-action="add-cat" data-type="income">+ 添加类别</button>'+
  '</div>'+
  '<h2 class="section-title">数据与更新</h2>'+
  '<div class="settings-row"><div class="lbl">共记录</div><div class="val">'+state.transactions.length+' 笔</div></div>'+
  '<div class="settings-row"><div><div class="lbl">本机数据</div><div class="val">同一 GitHub Pages 链接更新后会保留；换 repo 名或重装 App 前请先导出</div></div></div>'+
  '<div style="margin-top:10px;display:flex;gap:8px;flex-wrap:wrap;">'+
    '<button class="pill-btn" data-action="export-backup">导出备份 JSON</button>'+
    '<button class="pill-btn" data-action="import-backup">导入备份</button>'+
    '<button class="pill-btn" data-action="export-csv">导出 CSV</button>'+
    '<button class="pill-btn" data-action="update-app">刷新到最新版</button>'+
  '</div>'+
  '<div style="margin-top:14px;"><button class="pill-btn" style="color:var(--expense);" data-action="clear-all">清空全部数据</button></div>';
}

function attachHandlers(){
  document.querySelectorAll('[data-action]').forEach(el=>{ el.onclick = (e)=>handleAction(el.dataset, e); });
  const countrySel = document.getElementById('countrySelect');
  if(countrySel && !countrySel._bound){
    countrySel._bound = true;
    countrySel.onchange = async (e)=>{
      state.settings.country = e.target.value;
      state.settings.baseCurrency = e.target.value==='CN' ? 'CNY':'USD';
      ui.entryCurrency = state.settings.baseCurrency;
      await saveSettings();
      render();
    };
  }
  const amountInput = document.getElementById('amountInput');
  if(amountInput) amountInput.oninput = updateConvertNote;
  const receiptDrop = document.getElementById('receiptDrop');
  const receiptFile = document.getElementById('receiptFile');
  if(receiptDrop){ receiptDrop.onclick = ()=>receiptFile.click(); }
  if(receiptFile){ receiptFile.onchange = handleReceiptUpload; }
  const backupFile = document.getElementById('backupFile');
  if(backupFile && !backupFile._bound){ backupFile._bound = true; backupFile.onchange = handleBackupImport; }
  updateConvertNote();
}

function updateConvertNote(){
  const note = document.getElementById('convertNote');
  if(!note) return;
  const amtEl = document.getElementById('amountInput');
  const amt = parseFloat(amtEl && amtEl.value) || 0;
  if(amt<=0){ note.textContent=''; return; }
  const other = ui.entryCurrency==='CNY' ? 'USD' : 'CNY';
  const converted = convert(amt, ui.entryCurrency, other);
  note.textContent = '≈ '+(other==='CNY'?'¥':'$')+converted.toFixed(2)+' '+other;
}

async function handleAction(ds, e){
  switch(ds.action){
    case 'set-type': ui.type = ds.val; render(); break;
    case 'pick-cat': ui.selectedCat = ds.id; render(); break;
    case 'pick-income-cat': ui.selectedIncomeCat = ds.id; render(); break;
    case 'set-cur': ui.entryCurrency = ds.val; render(); break;
    case 'set-period': ui.dashPeriod = ds.val; ui.dashOffset = 0; render(); break;
    case 'nav-period': ui.dashOffset += parseInt(ds.val); render(); break;
    case 'submit-expense': await submitExpense(); break;
    case 'submit-income': await submitIncome(); break;
    case 'edit-tx': startEditTransaction(ds.id); break;
    case 'delete-tx': await deleteTransaction(ds.id); break;
    case 'cancel-edit': cancelEdit(); break;
    case 'add-cat': openCategoryModal(ds.type); break;
    case 'del-cat': await delCategory(ds.type, ds.id); break;
    case 'add-budget': await addBudget(); break;
    case 'del-budget': await delBudget(ds.id); break;
    case 'refresh-rate': await refreshRate(true); break;
    case 'export-backup': exportBackup(); break;
    case 'import-backup': document.getElementById('backupFile').click(); break;
    case 'export-csv': exportCSV(); break;
    case 'update-app': await updateAppShell(); break;
    case 'toggle-theme-settings':
      state.settings.theme = state.settings.theme==='dark' ? 'light':'dark';
      applyTheme(); await saveSettings(); render(); break;
    case 'clear-all': await clearAll(); break;
  }
}

function clearEditState(){
  ui.editingId=null; ui.editAmount=''; ui.editVendor=''; ui.editDate='';
}
function cancelEdit(){
  clearEditState();
  ui.lastAmount=''; ui.lastVendor=''; ui.receiptImg=null;
  render();
}
function startEditTransaction(id){
  const tx = state.transactions.find(t=>t.id===id);
  if(!tx){ toast('找不到这笔记录'); return; }
  ui.editingId = id;
  ui.tab = 'add';
  ui.type = tx.type;
  ui.entryCurrency = tx.currency;
  ui.editAmount = tx.amount;
  ui.editDate = isoToLocalInput(tx.date);
  ui.editVendor = tx.vendor || '';
  if(tx.type==='expense') ui.selectedCat = tx.categoryId;
  else ui.selectedIncomeCat = tx.categoryId;
  render();
}
async function deleteTransaction(id){
  const tx = state.transactions.find(t=>t.id===id);
  if(!tx) return;
  if(!confirm('确定删除这笔记录吗？')) return;
  state.transactions = state.transactions.filter(t=>t.id!==id);
  await saveTransactions();
  if(ui.editingId===id) clearEditState();
  toast('已删除记录');
  render();
}
async function submitExpense(){
  const amount = parseFloat(document.getElementById('amountInput').value);
  if(!amount || amount<=0){ toast('请输入金额'); return; }
  const vendor = document.getElementById('vendorInput').value.trim();
  const dateVal = document.getElementById('txDate').value;
  const txData = {
    type:'expense', categoryId: ui.selectedCat,
    vendor: vendor || null, amount, currency: ui.entryCurrency,
    date: dateVal ? new Date(dateVal).toISOString() : new Date().toISOString(),
    country: state.settings.country
  };
  if(ui.editingId){
    const idx = state.transactions.findIndex(t=>t.id===ui.editingId);
    if(idx>=0) state.transactions[idx] = Object.assign({}, state.transactions[idx], txData);
    toast('已保存修改');
  } else {
    state.transactions.push(Object.assign({id:'tx_'+Date.now()}, txData));
    toast('已记录支出');
  }
  await saveTransactions();
  clearEditState();
  ui.receiptImg=null; ui.lastAmount=''; ui.lastVendor='';
  render();
}
async function submitIncome(){
  const amount = parseFloat(document.getElementById('amountInputIncome').value);
  if(!amount || amount<=0){ toast('请输入金额'); return; }
  const dateVal = document.getElementById('txDate').value;
  const txData = { type:'income', categoryId: ui.selectedIncomeCat, amount, currency: ui.entryCurrency, date: dateVal ? new Date(dateVal).toISOString() : new Date().toISOString(), country: state.settings.country };
  if(ui.editingId){
    const idx = state.transactions.findIndex(t=>t.id===ui.editingId);
    if(idx>=0) state.transactions[idx] = Object.assign({}, state.transactions[idx], txData, {vendor:null});
    toast('已保存修改');
  } else {
    state.transactions.push(Object.assign({id:'tx_'+Date.now()}, txData));
    toast('已记录收入');
  }
  await saveTransactions();
  clearEditState();
  render();
}

function openCategoryModal(type){
  ui.modalType = type; ui.modalIcon = 'other';
  const keys = type==='expense' ? EXPENSE_ICON_KEYS : INCOME_ICON_KEYS;
  document.getElementById('modalNameInput').value = '';
  document.getElementById('modalIconGrid').innerHTML = keys.map(k=>'<div class="mi '+(k===ui.modalIcon?'selected':'')+'" data-icon="'+k+'">'+svgIcon(k)+'</div>').join('');
  document.querySelectorAll('#modalIconGrid .mi').forEach(el=>{
    el.onclick = ()=>{
      ui.modalIcon = el.dataset.icon;
      document.querySelectorAll('#modalIconGrid .mi').forEach(m=>m.classList.toggle('selected', m.dataset.icon===ui.modalIcon));
    };
  });
  document.getElementById('modalOverlay').classList.remove('hidden');
}
document.getElementById('modalCancel').onclick = ()=>{ document.getElementById('modalOverlay').classList.add('hidden'); };
document.getElementById('modalSave').onclick = async ()=>{
  const name = document.getElementById('modalNameInput').value.trim();
  if(!name){ toast('请输入类别名称'); return; }
  const id = ui.modalType+'_'+Date.now();
  state.categories[ui.modalType].push({id, name, icon:ui.modalIcon, custom:true});
  await saveCategories();
  document.getElementById('modalOverlay').classList.add('hidden');
  render();
};

async function delCategory(type,id){
  state.categories[type] = state.categories[type].filter(c=>c.id!==id);
  await saveCategories();
  render();
}
async function addBudget(){
  const period = document.getElementById('budgetPeriod').value;
  const category = document.getElementById('budgetCategory').value || null;
  const amount = parseFloat(document.getElementById('budgetAmount').value);
  if(!amount || amount<=0){ toast('请输入预算金额'); return; }
  state.budgets.push({ id:'bg_'+Date.now(), period, category, amount });
  await saveBudgets();
  toast('预算已设定');
  render();
}
async function delBudget(id){
  state.budgets = state.budgets.filter(b=>b.id!==id);
  await saveBudgets();
  render();
}
function downloadText(filename, text, mime){
  const blob = new Blob([text], {type:mime || 'text/plain;charset=utf-8'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = filename; document.body.appendChild(a); a.click(); a.remove();
  setTimeout(()=>URL.revokeObjectURL(url), 1000);
}
function exportBackup(){
  writeSnapshot();
  const date = new Date().toISOString().slice(0,10);
  downloadText('family-ledger-backup-'+date+'.json', JSON.stringify(buildSnapshot(), null, 2), 'application/json;charset=utf-8');
  toast('备份已导出');
}
function csvCell(v){
  const s = String(v==null?'':v).replace(/"/g,'""');
  return /[",\n]/.test(s) ? '"'+s+'"' : s;
}
function exportCSV(){
  const header = ['id','type','date','category','vendor','amount','currency','country'];
  const rows = state.transactions.map(t=>{
    const catList = t.type==='expense'?state.categories.expense:state.categories.income;
    const cat = catList.find(c=>c.id===t.categoryId);
    return [t.id,t.type,t.date,cat?cat.name:t.categoryId,t.vendor||'',t.amount,t.currency,t.country||''];
  });
  const csv = [header, ...rows].map(r=>r.map(csvCell).join(',')).join('\n');
  const date = new Date().toISOString().slice(0,10);
  downloadText('family-ledger-transactions-'+date+'.csv', '\ufeff'+csv, 'text/csv;charset=utf-8');
  toast('CSV 已导出');
}
async function applyImportedBackup(backup){
  if(!backup || !Array.isArray(backup.transactions)) throw new Error('备份格式不正确');
  state.settings = Object.assign(state.settings, backup.settings || {});
  state.categories = backup.categories || state.categories;
  state.transactions = backup.transactions || [];
  state.budgets = backup.budgets || [];
  await saveSettings(); await saveCategories(); await saveTransactions(); await saveBudgets();
  writeSnapshot();
  ui.editingId=null; ui.tab='settings';
  render();
  toast('已导入备份');
}
function handleBackupImport(e){
  const file = e.target.files && e.target.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = async ev=>{
    try{ await applyImportedBackup(JSON.parse(ev.target.result)); }
    catch(err){ console.error(err); toast('导入失败：请选择正确的 JSON 备份'); }
    e.target.value = '';
  };
  reader.readAsText(file);
}
async function updateAppShell(){
  try{
    if('serviceWorker' in navigator){
      const regs = await navigator.serviceWorker.getRegistrations();
      await Promise.all(regs.map(r=>r.unregister()));
    }
    if(window.caches){
      const keys = await caches.keys();
      await Promise.all(keys.filter(k=>k.indexOf('family-ledger-pwa')>=0).map(k=>caches.delete(k)));
    }
    toast('正在刷新到最新版');
    setTimeout(()=>location.reload(), 500);
  }catch(e){ location.reload(); }
}

async function clearAll(){
  if(!confirm('确定清空所有记账数据吗？此操作不可撤销。')) return;
  state.transactions = []; state.budgets = [];
  await saveTransactions(); await saveBudgets();
  toast('已清空');
  render();
}

function handleReceiptUpload(e){
  const file = e.target.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = async (ev)=>{
    ui.receiptImg = ev.target.result;
    ui.ocrLoading = true;
    render();
    try{
      if(typeof Tesseract === 'undefined') throw new Error('OCR 库未加载');
      const result = await Tesseract.recognize(ui.receiptImg, 'eng');
      parseReceiptText(result.data.text || '');
    }catch(err){ toast('自动识别失败，请手动填写'); }
    ui.ocrLoading = false;
    render();
  };
  reader.readAsDataURL(file);
}
function parseReceiptText(text){
  const lines = text.split('\n').map(l=>l.trim()).filter(Boolean);
  const numRegex = /[\$¥￥]?\s?(\d{1,6}(?:[.,]\d{2}))\b/g;
  let candidates = [];
  lines.forEach(line=>{
    let m;
    while((m = numRegex.exec(line)) !== null){
      const val = parseFloat(m[1].replace(',', '.'));
      if(!isNaN(val) && val>0 && val<1000000){
        candidates.push({val, isTotalLine:/total|合计|amount due|应付|实付/i.test(line)});
      }
    }
  });
  let amount = null;
  const totalMatch = candidates.find(c=>c.isTotalLine);
  if(totalMatch) amount = totalMatch.val;
  else if(candidates.length>0) amount = Math.max(...candidates.map(c=>c.val));
  let vendor = null;
  for(const line of lines){
    if(line.length>=2 && !/^\d+[\d.,\s]*$/.test(line)){ vendor = line.slice(0,40); break; }
  }
  if(amount) ui.lastAmount = amount;
  if(vendor) ui.lastVendor = vendor;
  toast('识别完成，请核对金额与商家');
}

document.querySelectorAll('nav.tabbar button').forEach(b=>{ b.onclick = ()=>{ ui.tab = b.dataset.tab; render(); }; });

(async function init(){
  await loadState();
  renderRateNote();
  render();
  refreshRate(false);
})();

if('serviceWorker' in navigator){
  window.addEventListener('load', ()=>{
    navigator.serviceWorker.register('./service-worker.js')
      .catch(err=>console.warn('Service Worker 注册失败:', err));
  });
}

</script>
</body>
</html>
